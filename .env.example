# Database (PostgreSQL)
# Recomendado: Neon.tech (gratuito) ou Vercel Postgres
DATABASE_URL="postgresql://user:password@host:5432/sabor_gym_rats?sslmode=require"

# JWT Secret — gere um valor aleatório forte, ex: openssl rand -base64 32
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"

# Senha do usuário admin criado pelo seed (obrigatório em produção)
ADMIN_PASSWORD="troque-pela-senha-do-admin"

# URL base da aplicação (sem barra final)
# Em produção no Netlify, use a URL do seu site (ex: https://seusite.netlify.app)
# O Netlify também injeta automaticamente a variável $URL — veja email.ts
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email — Resend (https://resend.com)
# Obtenha sua chave em: https://resend.com/api-keys
# Necessário para: recuperação de senha, verificação de e-mail
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@seudominio.com"
